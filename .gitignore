########################################################
# GitIgnore for R + Quarto Project
# Keeps repository clean from temporary and local files
########################################################


############################
# R temporary files
############################

# R session history
*.Rhistory

# Saved R workspace (rarely needed, not reproducible)
*.RData


############################
# RStudio / R project files
############################

# RStudio project user-specific settings
.Rproj.user/
.Rproj.user

# Alternative RStudio project cache/settings folder
.Rproj.user/


############################
# Quarto / Posit tools
############################

# Posit AI / assistant related local files (if generated)
.positai


############################
# Quarto render outputs
############################

# Quarto cache and intermediate render directory
/.quarto/

# Rendered report (generated by render.R or the CI workflow; published to GitHub Pages)
Quarto_Script.html

# Quarto supporting-files folder (when embed-resources is disabled)
/Quarto_Script_files/

# Assembled site directory used by the GitHub Pages workflow
/_site/


############################
# Example dataset (downloaded, not versioned)
############################

# The Big Five demo dataset is fetched at build time from openpsychometrics.org
/BIG5_data/
big5.zip


############################
# Operating system files
############################

# Windows thumbnail cache
Thumbs.db
